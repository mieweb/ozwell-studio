{
  "mcpServers": {
    "filesystem": {
      "command": "npx",
      "args": ["-y", "@j0hanz/filesystem-mcp@latest", "/workspace"],
      "transportType": "stdio"
    },
    "tmux": {
      "command": "npx",
      "args": ["-y", "tmux-mcp"],
      "transportType": "stdio"
    },
    "git": {
      "command": "uvx",
      "args": ["mcp-server-git"],
      "transportType": "stdio"
    }
  }
}
