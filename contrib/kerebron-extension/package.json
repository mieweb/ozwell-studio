{
  "name": "kerebron-extension",
  "displayName": "kerebron-extension",
  "description": "",
  "version": "0.0.1",
  "repository": "TODO",
  "engines": {
    "vscode": "^1.101.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/index.js",
  "contributes": {
    "commands": [
      {
        "command": "kerebron-extension.helloWorld",
        "title": "Hello World"
      }
    ],
    "customEditors": [
      {
        "viewType": "kerebronEditor",
        "displayName": "WYSIWYG Editor",
        "selector": [
          {
            "filenamePattern": "*.odt"
          },
          {
            "filenamePattern": "*.md"
          }
        ]
      }
    ]
  },
  "scripts": {
    "package": "vsce package",
    "vscode:prepublish": "npm run compile",
    "compile": "tsc --noCheck -p ./tsconfig.json --outDir ./dist",
    "watch": "tsc -watch --noCheck -p ./tsconfig.json --outDir ./dist",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint extension",
    "test": "vscode-test"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "20.x",
    "@types/vscode": "^1.101.0",
    "@typescript-eslint/eslint-plugin": "^8.31.1",
    "@typescript-eslint/parser": "^8.31.1",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "3.9.1",
    "eslint": "^9.25.1",
    "typescript": "^5.8.3"
  }
}
